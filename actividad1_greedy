def merge(S, inicio, fin): #recibe la lista de sensores y el rango a ordenar
    R = [None] * (fin - inicio + 1) #crea arreglo auxilixar del tamaño del rango a ordenar
    medio = (inicio + fin) // 2 
    i = inicio
    j = medio + 1 #i apunta al inicio de la mitad izq / j al inicio de la der

    for k in range(fin - inicio + 1):
        if (j > fin) or (i <= medio and S[i][0] <= S[j][0]):
            R[k] = S[i]
            i += 1
        else:
            R[k] = S[j]
            j += 1
#recorre posicion por posicion 

    for k in range(fin - inicio + 1):
        S[inicio + k] = R[k]
#copia el resultado auxiliar de vuelta al vector original 


def mergesort(S, inicio, fin):
    if inicio < fin:
        medio = (fin + inicio) // 2
        mergesort(S, inicio, medio)
        mergesort(S, medio + 1, fin)
        merge(S, inicio, fin)
#caso base implicito cuando inicio >= fin, no hace nada, lo que significa que el subarreglo de un solo elemento ya está ordenado


def greedy_sensores(sensores, L):
    n = len(sensores)
    if n == 0:
        return None
#sin sensores no se puede cubrir nada

    C = list(sensores)
    mergesort(C, 0, n - 1)
#copia los sensores para mo modificar el original y los ordena por inicio de intervalo 

    S = []
    cobertura_actual = 0
    idx = 0
#s = solcuion parcial 
#cobertura_actual = hasta donde se ha cubierto la ruta
#idx = puntero sobre c 

    while cobertura_actual < L and idx < n: #condicion 
        mejor = None
        while idx < n and C[idx][0] <= cobertura_actual:
            if mejor is None or C[idx][1] > mejor[1]:
                mejor = C[idx]
            idx += 1
#seleccionar todos los sensores cuyo inicio cubre la pos actual 

        if mejor is None:
            print("No hay solución.")
            return

        S.append(mejor)
        cobertura_actual = mejor[1]

    if cobertura_actual >= L:
        print(f"Sensores seleccionados ({len(S)}): {S}")
    else:
        print("No hay solución.")


# casos de prueba
# Caso del enunciado
sensores1 = [(0,2), (1,5), (3,6), (5,8)]
greedy_sensores(sensores1, 8)
print()

# Caso 1: muchos sensores pero greedy elige los mínimos
# hay 6 sensores pero la solución óptima usa solo 2
sensores2 = [(0,3), (2,4), (2,6), (4,7), (5,8), (8,9), (8,10)]
greedy_sensores(sensores2, 10)
print()

# Caso 2: sensores desordenados con mucho solapamiento
# greedy tiene que ordenarlos primero y elegir bien
sensores3 = [(0,8), (2,7), (5,8), (0,2)]
greedy_sensores(sensores3, 8)
print()

# Caso 3: no se puede cubrir la ruta (hay un hueco)
sensores4 = [(0,3), (5,8), (7,10)]
greedy_sensores(sensores4, 10)

#Caso 4: un solo sensor que cubre toda la ruta
sensores5 = [(0,10)]
greedy_sensores(sensores5, 10)


#complejidad temporal 
# O(n log n) por el mergesort + O(n) para seleccionar los sensores, total O(n log n) debido al ordenamiento.

